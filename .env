# ===========================================
# GARLIC MICROSERVICES - ENVIRONMENT CONFIG
# ===========================================

# PostgreSQL Configuration
POSTGRES_USER=garlic
POSTGRES_PASSWORD=garlic_secure_password_2024
POSTGRES_ROOT_PASSWORD=root_secure_password_2024

# Database Names
DB_AUTH=garlic_auth
DB_PRODUCT=garlic_product
DB_ORDER=garlic_order
DB_INVENTORY=garlic_inventory
DB_PAYMENT=garlic_payment
DB_SEARCH=garlic_search
DB_NOTIFICATION=garlic_notification
DB_CONFIG=garlic_config

# Kafka Configuration
KAFKA_PASSWORD=kafka_secure_password_2024
KAFKA_ZOOKEEPER_PASSWORD=zookeeper_secure_password_2024

# JWT Configuration
JWT_SECRET=garlic_jwt_secret_key_change_in_production_min_256_bits
JWT_EXPIRATION=86400000

# Kong Configuration
KONG_DATABASE_PASSWORD=kong_database_password_2024
KONG_JWT_SECRET=kong_jwt_secret_key_for_token_validation

# Redis Configuration
REDIS_PASSWORD=redis_secure_password_2024

# Elasticsearch
ELASTICSEARCH_PASSWORD=elasticsearch_secure_password_2024

# Kibana
KIBANA_PASSWORD=kibana_secure_password_2024

# Application Ports
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
KONGA_PORT=1337
EUREKA_PORT=8761
CONFIG_SERVER_PORT=8888
AUTH_PORT=8081
PRODUCT_PORT=8082
ORDER_PORT=8083
INVENTORY_PORT=8084
PAYMENT_PORT=8085
SEARCH_PORT=8086
NOTIFICATION_PORT=8087
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_PORT=16686
KIBANA_PORT=5601
ELASTICSEARCH_PORT=9200
REDIS_PORT=6379

# Logging
LOGSTASH_PORT=5044

# Java Options
JAVA_OPTS=-Xmx512m -Xms256m
